# Canais
TELEGRAM_TOKEN=coloque-o-token-do-BotFather-aqui

# IA (Google AI Studio)
GEMINI_API_KEY=coloque-a-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# Banco (PostgreSQL via docker-compose). Use o driver asyncpg.
DATABASE_URL=postgresql+asyncpg://pedro:pedro@localhost:5432/pedro_financas

# Comprovantes
RECEIPT_STORAGE_BACKEND=filesystem
RECEIPT_STORAGE_DIR=data/receipts

# Observabilidade
LOG_LEVEL=INFO
LOG_JSON=false
