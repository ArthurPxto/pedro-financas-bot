# Canais
TELEGRAM_TOKEN=coloque-o-token-do-BotFather-aqui

# IA (Google AI Studio)
GEMINI_API_KEY=coloque-a-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# Banco (PostgreSQL via docker-compose). Use o driver asyncpg.
DATABASE_URL=postgresql+asyncpg://pedro:pedro@localhost:5432/pedro_financas

# Comprovantes
RECEIPT_STORAGE_BACKEND=filesystem
RECEIPT_STORAGE_DIR=data/receipts

# Painel web / API (Fase 3) — opcional para o bot; obrigatório para /login e a API
WEB_JWT_SECRET=troque-por-um-segredo-aleatorio-longo
WEB_BASE_URL=http://localhost:5173
WEB_CORS_ORIGINS=*
API_HOST=0.0.0.0
API_PORT=8000

# Observabilidade
LOG_LEVEL=INFO
LOG_JSON=false
